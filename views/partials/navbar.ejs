<nav class="navbar">
  <a href="/" class="navbar__brand">
    <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
      <path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"/>
      <path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"/>
    </svg>
    Shrtn.
  </a>

  <div class="navbar__spacer"></div>

  <div class="navbar__links">
    <% if (typeof user !== 'undefined' && user) { %>
      <a href="/" class="navbar__link <%= typeof activePage !== 'undefined' && activePage === 'home' ? 'active' : '' %>">Home</a>
      <% if (user.role === 'ADMIN') { %>
        <a href="/admin/urls" class="navbar__link <%= typeof activePage !== 'undefined' && activePage === 'admin' ? 'active' : '' %>">Admin</a>
      <% } %>
      <div class="navbar__user">
        <div class="navbar__user-avatar">
          <%= (user.name || user.email || 'U').charAt(0).toUpperCase() %>
        </div>
        <span><%= user.name || user.email %></span>
      </div>
      <a href="/user/logout" class="btn-logout">Logout</a>
    <% } else { %>
      <a href="/login" class="navbar__link <%= typeof activePage !== 'undefined' && activePage === 'login' ? 'active' : '' %>">Login</a>
      <a href="/signup" class="btn btn-primary btn-sm">Sign up</a>
    <% } %>

    <button class="btn-icon" id="theme-toggle" aria-label="Toggle theme" title="Toggle theme">
      <!-- icon injected by theme.js -->
    </button>
  </div>
</nav>
